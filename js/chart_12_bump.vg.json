{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "The rise and fall of dynasties",
    "subtitle": "Final ladder position for every club to win a premiership 2000 to 2024. Hover any line to highlight that club's path.",
    "anchor": "start",
    "frame": "group",
    "offset": 8,
    "font": "'Source Sans 3', system-ui, sans-serif",
    "subtitleFont": "'Source Sans 3', system-ui, sans-serif",
    "fontSize": 18,
    "fontWeight": 600,
    "subtitleFontSize": 13,
    "subtitleColor": "#5a5a5a"
  },
  "width": "container",
  "height": 460,
  "padding": {
    "left": 0,
    "top": 8,
    "right": 90,
    "bottom": 0
  },
  "background": null,
  "data": {
    "url": "data/bump_ladder.csv"
  },
  "transform": [
    {
      "calculate": "datum.team == 'Brisbane Lions' ? 'Brisbane' : (datum.team == 'West Coast' ? 'W. Coast' : datum.team)",
      "as": "label"
    }
  ],
  "encoding": {
    "x": {
      "field": "year",
      "type": "quantitative",
      "title": null,
      "scale": {
        "domain": [
          1999,
          2025
        ]
      },
      "axis": {
        "format": "d",
        "tickCount": 7,
        "labelFont": "'Source Sans 3', system-ui, sans-serif",
        "labelFontSize": 11
      }
    },
    "y": {
      "field": "rank",
      "type": "quantitative",
      "title": "Final ladder position",
      "scale": {
        "domain": [
          18.5,
          0.5
        ]
      },
      "axis": {
        "values": [
          1,
          4,
          8,
          12,
          18
        ],
        "labelFont": "'Source Sans 3', system-ui, sans-serif",
        "titleFont": "'Source Sans 3', system-ui, sans-serif",
        "labelFontSize": 10
      }
    }
  },
  "layer": [
    {
      "data": {
        "values": [
          {
            "y1": 0.5,
            "y2": 8.5,
            "label": "Finals"
          }
        ]
      },
      "mark": {
        "type": "rect",
        "fill": "#f4ebd9",
        "opacity": 0.55
      },
      "encoding": {
        "y": {
          "field": "y1",
          "type": "quantitative"
        },
        "y2": {
          "field": "y2"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "x": 1999.3,
            "y": 1.3,
            "label": "Finals zone (top 8)"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "fontSize": 10,
        "fontStyle": "italic",
        "color": "#7a5a1e",
        "font": "'Source Sans 3', system-ui, sans-serif"
      },
      "encoding": {
        "x": {
          "field": "x",
          "type": "quantitative"
        },
        "y": {
          "field": "y",
          "type": "quantitative"
        },
        "text": {
          "field": "label"
        }
      }
    },
    {
      "mark": {
        "type": "line",
        "interpolate": "monotone",
        "strokeWidth": 2.5
      },
      "encoding": {
        "color": {
          "field": "team",
          "type": "nominal",
          "title": "Club",
          "scale": {
            "domain": [
              "Collingwood",
              "Hawthorn",
              "Geelong",
              "Brisbane Lions",
              "Richmond",
              "Sydney"
            ],
            "range": [
              "#1a1a1a",
              "#5c4a1e",
              "#3a6e3a",
              "#4a2466",
              "#c8932b",
              "#d6471f"
            ]
          },
          "legend": null
        },
        "detail": {
          "field": "team",
          "type": "nominal"
        },
        "tooltip": [
          {
            "field": "team",
            "type": "nominal",
            "title": "Club"
          },
          {
            "field": "year",
            "type": "quantitative",
            "title": "Year"
          },
          {
            "field": "rank",
            "type": "quantitative",
            "title": "Finished"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "circle",
        "size": 45,
        "opacity": 0.8
      },
      "encoding": {
        "color": {
          "field": "team",
          "type": "nominal",
          "scale": {
            "domain": [
              "Collingwood",
              "Hawthorn",
              "Geelong",
              "Brisbane Lions",
              "Richmond",
              "Sydney"
            ],
            "range": [
              "#1a1a1a",
              "#5c4a1e",
              "#3a6e3a",
              "#4a2466",
              "#c8932b",
              "#d6471f"
            ]
          },
          "legend": null
        },
        "tooltip": [
          {
            "field": "team",
            "type": "nominal",
            "title": "Club"
          },
          {
            "field": "year",
            "type": "quantitative",
            "title": "Year"
          },
          {
            "field": "rank",
            "type": "quantitative",
            "title": "Finished"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.year == 2025"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 8,
        "fontSize": 10,
        "fontWeight": 600,
        "font": "'Source Sans 3', system-ui, sans-serif"
      },
      "encoding": {
        "text": {
          "field": "label",
          "type": "nominal"
        },
        "color": {
          "field": "team",
          "type": "nominal",
          "scale": {
            "domain": [
              "Collingwood",
              "Hawthorn",
              "Geelong",
              "Brisbane Lions",
              "Richmond",
              "Sydney"
            ],
            "range": [
              "#1a1a1a",
              "#5c4a1e",
              "#3a6e3a",
              "#4a2466",
              "#c8932b",
              "#d6471f"
            ]
          },
          "legend": null
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "x1": 2001,
            "x2": 2003,
            "label": "Brisbane threepeat"
          },
          {
            "x1": 2007,
            "x2": 2011,
            "label": "Geelong era"
          },
          {
            "x1": 2013,
            "x2": 2015,
            "label": "Hawthorn threepeat"
          },
          {
            "x1": 2017,
            "x2": 2020,
            "label": "Richmond era"
          }
        ]
      },
      "mark": {
        "type": "rule",
        "color": "#999999",
        "strokeDash": [
          2,
          2
        ],
        "opacity": 0.4
      },
      "encoding": {
        "x": {
          "field": "x1",
          "type": "quantitative"
        },
        "x2": {
          "field": "x2"
        },
        "y": {
          "datum": 0.5
        },
        "y2": {
          "datum": 18.5
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "x": 2002,
            "y": 18.3,
            "label": "Brisbane threepeat"
          },
          {
            "x": 2009,
            "y": 18.3,
            "label": "Geelong era"
          },
          {
            "x": 2014,
            "y": 18.3,
            "label": "Hawthorn threepeat"
          },
          {
            "x": 2018.5,
            "y": 18.3,
            "label": "Richmond era"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "center",
        "fontSize": 9,
        "fontStyle": "italic",
        "color": "#5a5a5a",
        "font": "'Source Sans 3', system-ui, sans-serif"
      },
      "encoding": {
        "x": {
          "field": "x",
          "type": "quantitative"
        },
        "y": {
          "field": "y",
          "type": "quantitative"
        },
        "text": {
          "field": "label"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "domainColor": "#cccccc",
      "tickColor": "#cccccc",
      "labelColor": "#5a5a5a",
      "grid": false
    },
    "font": "'Source Sans 3', system-ui, sans-serif"
  }
}