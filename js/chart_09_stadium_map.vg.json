{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Every stadium that has hosted AFL football",
    "subtitle": "Bubble size shows total matches at each ground. Use the dropdown below the map to focus on a state.",
    "anchor": "start",
    "frame": "group",
    "offset": 8,
    "font": "'Source Sans 3', system-ui, sans-serif",
    "subtitleFont": "'Source Sans 3', system-ui, sans-serif",
    "fontSize": 18,
    "fontWeight": 600,
    "subtitleFontSize": 13,
    "subtitleColor": "#5a5a5a"
  },
  "width": "container",
  "height": 560,
  "padding": { "left": 0, "top": 0, "right": 16, "bottom": 0 },
  "background": null,
  "params": [
    {
      "name": "state_filter",
      "value": "All",
      "bind": {
        "input": "select",
        "options": ["All", "Victoria", "New South Wales", "Queensland", "Western Australia", "South Australia", "Tasmania", "Northern Territory", "Australian Capital Territory"],
        "labels": ["All states", "Victoria", "New South Wales", "Queensland", "Western Australia", "South Australia", "Tasmania", "Northern Territory", "ACT"],
        "name": "Focus on: "
      }
    }
  ],
  "projection": {
    "type": "mercator",
    "center": [134, -28],
    "scale": 700
  },
  "layer": [
    {
      "data": {
        "url": "js/au_states.json",
        "format": { "type": "json", "property": "features" }
      },
      "mark": { "type": "geoshape", "fill": "#f4ebd9", "stroke": "#d8cfb8", "strokeWidth": 1 },
      "encoding": {
        "tooltip": { "field": "properties.STATE_NAME", "type": "nominal", "title": "State" }
      }
    },
    {
      "data": { "url": "data/venues.csv" },
      "mark": { "type": "circle", "stroke": "#a0252f", "strokeWidth": 1 },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude":  { "field": "lat", "type": "quantitative" },
        "size": {
          "field": "matches",
          "type": "quantitative",
          "title": "Matches hosted",
          "scale": { "range": [50, 2200] },
          "legend": {
            "format": ",d",
            "labelFont": "'Source Sans 3', system-ui, sans-serif",
            "titleFont": "'Source Sans 3', system-ui, sans-serif"
          }
        },
        "color": {
          "condition": { "test": "state_filter == 'All' || datum.state == state_filter", "value": "#a0252f" },
          "value": "#dddddd"
        },
        "opacity": {
          "condition": { "test": "state_filter == 'All' || datum.state == state_filter", "value": 0.75 },
          "value": 0.2
        },
        "tooltip": [
          { "field": "venue", "type": "nominal", "title": "Stadium" },
          { "field": "state", "type": "nominal", "title": "State" },
          { "field": "matches", "type": "quantitative", "format": ",", "title": "Matches hosted" }
        ]
      }
    },
    {
      "data": { "values": [{ "venue": "M.C.G.", "lon": 144.9834, "lat": -37.82, "state": "Victoria" }] },
      "mark": { "type": "text", "font": "'Source Sans 3', system-ui, sans-serif", "fontSize": 11, "fontStyle": "italic", "fontWeight": 600, "color": "#1a1a1a", "align": "left", "dx": 15, "dy": -2 },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude":  { "field": "lat", "type": "quantitative" },
        "text":      { "field": "venue", "type": "nominal" },
        "opacity": { "condition": { "test": "state_filter == 'All' || datum.state == state_filter", "value": 1 }, "value": 0 }
      }
    },
    {
      "data": { "values": [{ "venue": "Princes Park", "lon": 144.9614, "lat": -37.7833, "state": "Victoria" }] },
      "mark": { "type": "text", "font": "'Source Sans 3', system-ui, sans-serif", "fontSize": 10, "fontStyle": "italic", "color": "#1a1a1a", "align": "right", "dx": -10, "dy": -18 },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude":  { "field": "lat", "type": "quantitative" },
        "text":      { "field": "venue", "type": "nominal" },
        "opacity": { "condition": { "test": "state_filter == 'All' || datum.state == state_filter", "value": 1 }, "value": 0 }
      }
    },
    {
      "data": { "values": [{ "venue": "Docklands", "lon": 144.9476, "lat": -37.8163, "state": "Victoria" }] },
      "mark": { "type": "text", "font": "'Source Sans 3', system-ui, sans-serif", "fontSize": 10, "fontStyle": "italic", "color": "#1a1a1a", "align": "right", "dx": -10, "dy": 16 },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude":  { "field": "lat", "type": "quantitative" },
        "text":      { "field": "venue", "type": "nominal" },
        "opacity": { "condition": { "test": "state_filter == 'All' || datum.state == state_filter", "value": 1 }, "value": 0 }
      }
    },
    {
      "data": { "values": [{ "venue": "Kardinia Park", "lon": 144.3547, "lat": -38.1583, "state": "Victoria" }] },
      "mark": { "type": "text", "font": "'Source Sans 3', system-ui, sans-serif", "fontSize": 10, "fontStyle": "italic", "color": "#1a1a1a", "align": "right", "dx": -8, "dy": 10 },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude":  { "field": "lat", "type": "quantitative" },
        "text":      { "field": "venue", "type": "nominal" },
        "opacity": { "condition": { "test": "state_filter == 'All' || datum.state == state_filter", "value": 1 }, "value": 0 }
      }
    },
    {
      "data": {
        "values": [
          { "venue": "S.C.G.",        "lon": 151.2247, "lat": -33.8917, "align": "left",  "dx": 12,  "dy": 0,   "state": "New South Wales" },
          { "venue": "Adelaide Oval", "lon": 138.5961, "lat": -34.9156, "align": "right", "dx": -12, "dy": -2,  "state": "South Australia" },
          { "venue": "Subiaco",       "lon": 115.8264, "lat": -31.9446, "align": "left",  "dx": 14,  "dy": -2,  "state": "Western Australia" },
          { "venue": "Gabba",         "lon": 153.0381, "lat": -27.4858, "align": "left",  "dx": 14,  "dy": -10, "state": "Queensland" }
        ]
      },
      "mark": { "type": "text", "font": "'Source Sans 3', system-ui, sans-serif", "fontSize": 10, "fontStyle": "italic", "color": "#1a1a1a" },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude":  { "field": "lat", "type": "quantitative" },
        "text":      { "field": "venue", "type": "nominal" },
        "opacity": { "condition": { "test": "state_filter == 'All' || datum.state == state_filter", "value": 1 }, "value": 0 }
      }
    }
  ],
  "config": {
    "view": { "stroke": null },
    "font": "'Source Sans 3', system-ui, sans-serif"
  }
}
