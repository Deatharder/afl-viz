{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Every stadium that has hosted AFL football",
    "subtitle": "Bubble size shows total matches at each ground. Use the dropdown below to zoom into a single state.",
    "anchor": "start",
    "frame": "group",
    "offset": 8,
    "font": "'Source Sans 3', system-ui, sans-serif",
    "subtitleFont": "'Source Sans 3', system-ui, sans-serif",
    "fontSize": 18,
    "fontWeight": 600,
    "subtitleFontSize": 13,
    "subtitleColor": "#5a5a5a"
  },
  "width": "container",
  "height": 560,
  "padding": { "left": 0, "top": 0, "right": 16, "bottom": 0 },
  "background": null,
  "params": [
    {
      "name": "state_filter",
      "value": "All",
      "bind": {
        "input": "select",
        "options": ["All", "Victoria", "New South Wales", "Queensland", "Western Australia", "South Australia", "Tasmania", "Northern Territory", "Australian Capital Territory"],
        "labels": ["Zoom: All Australia", "Zoom: Victoria", "Zoom: New South Wales", "Zoom: Queensland", "Zoom: Western Australia", "Zoom: South Australia", "Zoom: Tasmania", "Zoom: Northern Territory", "Zoom: ACT"],
        "name": "Focus on: "
      }
    },
    {
      "name": "proj_scale",
      "expr": "state_filter == 'All' ? 700 : state_filter == 'Victoria' ? 4500 : state_filter == 'New South Wales' ? 2400 : state_filter == 'Queensland' ? 1500 : state_filter == 'Western Australia' ? 1600 : state_filter == 'South Australia' ? 2200 : state_filter == 'Tasmania' ? 5000 : state_filter == 'Northern Territory' ? 1800 : 8000"
    },
    {
      "name": "proj_lon",
      "expr": "state_filter == 'All' ? 134 : state_filter == 'Victoria' ? 144.5 : state_filter == 'New South Wales' ? 148 : state_filter == 'Queensland' ? 148 : state_filter == 'Western Australia' ? 119 : state_filter == 'South Australia' ? 138 : state_filter == 'Tasmania' ? 147 : state_filter == 'Northern Territory' ? 132 : 149.13"
    },
    {
      "name": "proj_lat",
      "expr": "state_filter == 'All' ? -28 : state_filter == 'Victoria' ? -37.5 : state_filter == 'New South Wales' ? -33 : state_filter == 'Queensland' ? -25 : state_filter == 'Western Australia' ? -28 : state_filter == 'South Australia' ? -33 : state_filter == 'Tasmania' ? -42 : state_filter == 'Northern Territory' ? -20 : -35.28"
    }
  ],
  "projection": {
    "type": "mercator",
    "center": { "expr": "[proj_lon, proj_lat]" },
    "scale": { "expr": "proj_scale" }
  },
  "layer": [
    {
      "data": {
        "url": "js/au_states.json",
        "format": { "type": "json", "property": "features" }
      },
      "mark": { "type": "geoshape", "fill": "#f4ebd9", "stroke": "#d8cfb8", "strokeWidth": 1 },
      "encoding": {
        "tooltip": { "field": "properties.STATE_NAME", "type": "nominal", "title": "State" }
      }
    },
    {
      "data": { "url": "data/venues.csv" },
      "mark": { "type": "circle", "stroke": "#a0252f", "strokeWidth": 1 },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude":  { "field": "lat", "type": "quantitative" },
        "size": {
          "field": "matches",
          "type": "quantitative",
          "title": "Matches hosted",
          "scale": { "range": [50, 2200] },
          "legend": {
            "format": ",d",
            "labelFont": "'Source Sans 3', system-ui, sans-serif",
            "titleFont": "'Source Sans 3', system-ui, sans-serif"
          }
        },
        "color": {
          "condition": { "test": "state_filter == 'All' || datum.state == state_filter", "value": "#a0252f" },
          "value": "#dddddd"
        },
        "opacity": {
          "condition": { "test": "state_filter == 'All' || datum.state == state_filter", "value": 0.78 },
          "value": 0.15
        },
        "tooltip": [
          { "field": "venue", "type": "nominal", "title": "Stadium" },
          { "field": "state", "type": "nominal", "title": "State" },
          { "field": "matches", "type": "quantitative", "format": ",", "title": "Matches hosted" }
        ]
      }
    },
    {
      "data": { "url": "data/venues.csv" },
      "transform": [
        { "filter": "state_filter != 'All' && datum.state == state_filter" }
      ],
      "mark": {
        "type": "text",
        "font": "'Source Sans 3', system-ui, sans-serif",
        "fontSize": 10,
        "fontStyle": "italic",
        "color": "#1a1a1a",
        "align": "left",
        "dx": 14,
        "dy": 0
      },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude":  { "field": "lat", "type": "quantitative" },
        "text":      { "field": "venue", "type": "nominal" }
      }
    },
    {
      "data": {
        "values": [
          { "venue": "M.C.G.",        "lon": 144.9834, "lat": -37.82,    "state": "AllOnly" },
          { "venue": "S.C.G.",        "lon": 151.2247, "lat": -33.8917,  "state": "AllOnly" },
          { "venue": "Adelaide Oval", "lon": 138.5961, "lat": -34.9156,  "state": "AllOnly" },
          { "venue": "Subiaco",       "lon": 115.8264, "lat": -31.9446,  "state": "AllOnly" },
          { "venue": "Gabba",         "lon": 153.0381, "lat": -27.4858,  "state": "AllOnly" }
        ]
      },
      "transform": [
        { "filter": "state_filter == 'All'" }
      ],
      "mark": {
        "type": "text",
        "font": "'Source Sans 3', system-ui, sans-serif",
        "fontSize": 10,
        "fontStyle": "italic",
        "color": "#1a1a1a",
        "align": "left",
        "dx": 14
      },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude":  { "field": "lat", "type": "quantitative" },
        "text":      { "field": "venue", "type": "nominal" }
      }
    }
  ],
  "config": {
    "view": { "stroke": null },
    "font": "'Source Sans 3', system-ui, sans-serif"
  }
}
