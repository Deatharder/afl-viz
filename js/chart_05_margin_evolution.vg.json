{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "How close are matches?",
    "subtitle": "Average winning margin per year",
    "anchor": "start",
    "frame": "group",
    "offset": 6,
    "font": "Source Sans 3, system-ui, sans-serif",
    "subtitleFont": "Source Sans 3, system-ui, sans-serif",
    "fontSize": 14,
    "fontWeight": 600,
    "subtitleFontSize": 11,
    "subtitleColor": "#5a5a5a"
  },
  "width": "container",
  "height": 220,
  "padding": { "left": 0, "top": 0, "right": 16, "bottom": 0 },
  "background": null,
  "data": { "url": "data/avg_margin_per_year.csv" },
  "mark": { "type": "line", "color": "#2c5f5d", "strokeWidth": 1.8, "interpolate": "monotone" },
  "encoding": {
    "x": {
      "field": "year",
      "type": "quantitative",
      "title": null,
      "scale": { "domain": [1895, 2027] },
      "axis": { "format": "d", "tickCount": 5, "labelFont": "Source Sans 3, system-ui, sans-serif", "labelFontSize": 10 }
    },
    "y": {
      "field": "avg_margin",
      "type": "quantitative",
      "title": "Points",
      "axis": { "labelFont": "Source Sans 3, system-ui, sans-serif", "titleFont": "Source Sans 3, system-ui, sans-serif", "labelFontSize": 10, "tickMinStep": 10 }
    },
    "tooltip": [
      { "field": "year", "type": "quantitative", "title": "Year" },
      { "field": "avg_margin", "type": "quantitative", "format": ".1f", "title": "Avg margin" }
    ]
  },
  "config": { "view": { "stroke": null }, "axis": { "domainColor": "#cccccc", "tickColor": "#cccccc", "labelColor": "#5a5a5a", "grid": false } }
}