{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Premierships in the round",
    "subtitle": "Total flags per club, radial view",
    "anchor": "start",
    "frame": "group",
    "offset": 8,
    "font": "'Source Sans 3', system-ui, sans-serif",
    "subtitleFont": "'Source Sans 3', system-ui, sans-serif",
    "fontSize": 14,
    "fontWeight": 600,
    "subtitleFontSize": 11,
    "subtitleColor": "#5a5a5a"
  },
  "width": "container",
  "height": 380,
  "padding": { "left": 0, "top": 0, "right": 16, "bottom": 0 },
  "background": null,
  "data": { "url": "data/premierships_per_team.csv" },
  "transform": [
    { "filter": "datum.premierships > 0" },
    {
      "calculate": "datum.team == 'Greater Western Sydney' ? 'GWS' : (datum.team == 'Western Bulldogs' ? 'Bulldogs' : (datum.team == 'North Melbourne' ? 'Nth Melb' : (datum.team == 'Brisbane Lions' ? 'Brisbane' : (datum.team == 'Port Adelaide' ? 'Port' : datum.team))))",
      "as": "label"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "arc",
        "innerRadius": 30,
        "stroke": "#ffffff",
        "strokeWidth": 1.5
      },
      "encoding": {
        "theta": {
          "field": "team",
          "type": "nominal",
          "sort": { "field": "premierships", "order": "descending" },
          "stack": true
        },
        "radius": {
          "field": "premierships",
          "type": "quantitative",
          "scale": { "type": "linear", "range": [50, 150], "zero": true }
        },
        "color": {
          "field": "premierships",
          "type": "quantitative",
          "scale": { "scheme": "reds", "domain": [0, 16] },
          "legend": null
        },
        "tooltip": [
          { "field": "team", "type": "nominal", "title": "Club" },
          { "field": "premierships", "type": "quantitative", "title": "Premierships" }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "radiusOffset": 14,
        "font": "'Source Sans 3', system-ui, sans-serif",
        "fontSize": 10,
        "fontWeight": 600,
        "color": "#1a1a1a"
      },
      "encoding": {
        "theta": {
          "field": "team",
          "type": "nominal",
          "sort": { "field": "premierships", "order": "descending" },
          "stack": true,
          "bandPosition": 0.5
        },
        "radius": {
          "field": "premierships",
          "type": "quantitative",
          "scale": { "type": "linear", "range": [50, 150], "zero": true }
        },
        "text": { "field": "label", "type": "nominal" }
      }
    }
  ],
  "view": { "stroke": null },
  "config": {
    "view": { "stroke": null },
    "font": "'Source Sans 3', system-ui, sans-serif"
  }
}
