        "type": "rule",
        "color": "#1a1a1a",
        "strokeWidth": 1.2
      },
      "encoding": {
        "longitude": {
          "field": "lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "lat",
          "type": "quantitative"
        },
        "longitude2": {
          "field": "lon2"
        },
        "latitude2": {
          "field": "lat2"
        }
