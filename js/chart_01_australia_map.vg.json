{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Where the AFL is played",
    "subtitle": "Total matches in each state and territory, 1897 to 2025",
    "anchor": "start",
    "frame": "group",
    "offset": 8,
    "font": "'Source Sans 3', system-ui, sans-serif",
    "subtitleFont": "'Source Sans 3', system-ui, sans-serif",
    "fontSize": 18,
    "fontWeight": 600,
    "subtitleFontSize": 13,
    "subtitleColor": "#5a5a5a"
  },
  "width": "container",
  "height": 480,
  "padding": {
    "left": 0,
    "top": 0,
    "right": 60,
    "bottom": 0
  },
  "background": null,
  "projection": {
    "type": "mercator",
    "center": [
      134,
      -28
    ],
    "scale": 700
  },
  "layer": [
    {
      "data": {
        "url": "js/au_states.json",
        "format": {
          "type": "json",
          "property": "features"
        }
      },
      "transform": [
        {
          "lookup": "properties.STATE_NAME",
          "from": {
            "data": {
              "url": "data/matches_by_state.csv"
            },
            "key": "state",
            "fields": [
              "matches"
            ]
          }
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "white",
        "strokeWidth": 1
      },
      "encoding": {
        "color": {
          "field": "matches",
          "type": "quantitative",
          "title": "Matches played",
          "scale": {
            "scheme": "reds",
            "type": "log"
          },
          "legend": {
            "format": ",.0f",
            "orient": "right",
            "offset": 8,
            "titleFont": "'Source Sans 3', system-ui, sans-serif",
            "labelFont": "'Source Sans 3', system-ui, sans-serif"
          }
        },
        "tooltip": [
          {
            "field": "properties.STATE_NAME",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "matches",
            "type": "quantitative",
            "format": ",",
            "title": "Matches"
          }
        ]
      }
    },
    {
      "data": {
        "url": "js/au_states.json",
        "format": {
          "type": "json",
          "property": "features"
        }
      },
      "transform": [
        {
          "filter": "datum.properties.STATE_NAME == 'Victoria'"
        }
      ],
      "mark": {
        "type": "geoshape",
        "fill": null,
        "stroke": "#1a1a1a",
        "strokeWidth": 2
      }
    },
