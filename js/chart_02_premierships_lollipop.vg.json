{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Premierships won, by club",
    "subtitle": "Total Grand Final wins, 1897 to 2024",
    "anchor": "start",
    "frame": "group",
    "offset": 8,
    "font": "Source Sans 3, system-ui, sans-serif",
    "subtitleFont": "Source Sans 3, system-ui, sans-serif",
    "fontSize": 18,
    "fontWeight": 600,
    "subtitleFontSize": 13,
    "subtitleColor": "#5a5a5a"
  },
  "width": "container",
  "height": 420,
  "padding": { "left": 0, "top": 0, "right": 20, "bottom": 0 },
  "background": null,
  "data": { "url": "data/premierships_per_team.csv" },
  "transform": [{ "filter": "datum.premierships > 0" }],
  "layer": [
    {
      "mark": { "type": "rule", "color": "#a0252f", "strokeWidth": 2 },
      "encoding": {
        "y": {
          "field": "team",
          "type": "nominal",
          "sort": "-x",
          "title": null,
          "axis": {
            "labelFontSize": 12,
            "labelFont": "Source Sans 3, system-ui, sans-serif",
            "domain": false,
            "ticks": false
          }
        },
        "x":  { "datum": 0 },
        "x2": { "field": "premierships" }
      }
    },
    {
      "mark": { "type": "circle", "size": 260, "color": "#a0252f", "opacity": 1 },
      "encoding": {
        "y": {
          "field": "team",
          "type": "nominal",
          "sort": "-x"
        },
        "x": {
          "field": "premierships",
          "type": "quantitative",
          "title": "Premierships",
          "axis": {
            "format": "d",
            "labelFont": "Source Sans 3, system-ui, sans-serif",
            "titleFont": "Source Sans 3, system-ui, sans-serif",
            "tickMinStep": 2
          }
        },
        "tooltip": [
          { "field": "team", "type": "nominal", "title": "Club" },
          { "field": "premierships", "type": "quantitative", "title": "Premierships" }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "middle",
        "color": "#ffffff",
        "fontSize": 11,
        "fontWeight": 700,
        "font": "Source Sans 3, system-ui, sans-serif"
      },
      "encoding": {
        "y": {
          "field": "team",
          "type": "nominal",
          "sort": "-x"
        },
        "x": {
          "field": "premierships",
          "type": "quantitative"
        },
        "text": {
          "field": "premierships",
          "type": "quantitative",
          "format": "d"
        }
      }
    }
  ],
  "config": {
    "view": { "stroke": null },
    "axis": { "domainColor": "#cccccc", "tickColor": "#cccccc", "labelColor": "#5a5a5a" }
  }
}