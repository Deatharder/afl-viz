{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Premierships won, by club",
    "subtitle": "Total Grand Final wins, 1897 to 2024",
    "anchor": "start",
    "frame": "group",
    "offset": 8,
    "font": "'Source Sans 3', system-ui, sans-serif",
    "subtitleFont": "'Source Sans 3', system-ui, sans-serif",
    "fontSize": 18,
    "fontWeight": 600,
    "subtitleFontSize": 13,
    "subtitleColor": "#5a5a5a"
  },
  "width": "container",
  "height": 420,
  "padding": { "left": 0, "top": 0, "right": 20, "bottom": 0 },
  "background": null,
  "data": { "url": "data/premierships_per_team.csv" },
  "transform": [
    { "filter": "datum.premierships > 0" },
    {
      "calculate": "datum.team == 'Greater Western Sydney' ? 'GWS' : (datum.team == 'Western Bulldogs' ? 'W. Bulldogs' : (datum.team == 'North Melbourne' ? 'Nth Melbourne' : (datum.team == 'Brisbane Lions' ? 'Brisbane' : datum.team)))",
      "as": "team_short"
    }
  ],
  "encoding": {
    "y": {
      "field": "team_short",
      "type": "nominal",
      "sort": { "field": "premierships", "order": "descending" },
      "title": null,
      "axis": {
        "labelFontSize": 12,
        "labelFont": "'Source Sans 3', system-ui, sans-serif",
        "labelLimit": 200,
        "labelPadding": 8,
        "domain": false,
        "ticks": false
      }
    },
    "x": {
      "field": "premierships",
      "type": "quantitative",
      "title": "Premierships",
      "axis": {
        "format": "d",
        "labelFont": "'Source Sans 3', system-ui, sans-serif",
        "titleFont": "'Source Sans 3', system-ui, sans-serif",
        "tickMinStep": 2
      }
    }
  },
  "layer": [
    {
      "mark": { "type": "bar", "color": "#a0252f", "height": 2, "cornerRadius": 0 }
    },
    {
      "mark": { "type": "circle", "size": 280, "color": "#a0252f", "opacity": 1 },
      "encoding": {
        "tooltip": [
          { "field": "team", "type": "nominal", "title": "Club" },
          { "field": "premierships", "type": "quantitative", "title": "Premierships" }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "middle",
        "color": "#ffffff",
        "fontSize": 11,
        "fontWeight": 700,
        "font": "'Source Sans 3', system-ui, sans-serif"
      },
      "encoding": {
        "text": { "field": "premierships", "type": "quantitative", "format": "d" }
      }
    }
  ],
  "config": {
    "view": { "stroke": null },
    "axis": { "domainColor": "#cccccc", "tickColor": "#cccccc", "labelColor": "#5a5a5a" },
    "font": "'Source Sans 3', system-ui, sans-serif"
  }
}
